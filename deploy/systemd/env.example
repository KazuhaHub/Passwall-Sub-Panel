# Optional environment file for passwall-sub-panel.service.
# Copy to /opt/psp/.env (root:psp 640) and uncomment the systemd
# EnvironmentFile= line in passwall-sub-panel.service.
#
# Format: KEY=value  (no `export`, no shell quoting).
#
# Every PSP_* env var overrides the matching field in
# /opt/psp/config/config.yaml. Use this when you'd rather keep secrets
# out of the YAML — e.g. when the file is version-controlled or shared
# between hosts.

# Trusted reverse-proxy CIDRs (comma-separated). "none" disables the
# trust list entirely. Empty / unset = trust everything (zero-config
# default — assumes the panel's listen port is NOT publicly reachable).
# PSP_TRUSTED_PROXIES=10.0.0.0/8,127.0.0.1

# 32+ byte secret used to derive the at-rest encryption key for SAML
# secrets, OIDC client_secret, 3X-UI panel credentials, SMTP password.
# CHANGING THIS BREAKS DECRYPTION of every existing encrypted row —
# rotate only with a planned re-encryption pass.
# PSP_SECRET_KEY_MATERIAL=replace-with-32+byte-random-string

# Override the JWT signing key (otherwise auto-generated and stored in
# the DB at first run).
# PSP_JWT_SECRET=replace-with-strong-random-secret
