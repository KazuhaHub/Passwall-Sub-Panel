# Passwall-Sub-Panel main config example.
# Copy to config.yaml and fill in jwt_secret (or set PSP_JWT_SECRET).
# Database is zero-config by default: if mysql.dsn is omitted or empty, the
# panel uses SQLite at <data_dir>/panel.db.
#
# All other settings (sub_base_url, cron cadence, JWT TTLs, rate limits,
# login mode, new-user defaults, etc.) are stored in the database and
# managed via Admin -> Settings. They are NOT read from this file.

listen: ":8788"

# Reverse proxy / real client IP handling.
#
# Default (this block unset): zero-config — the panel trusts all upstream
# IPs and reads the real client IP from CF-Connecting-IP / X-Real-IP /
# X-Forwarded-For (in that order). Works out of the box behind nginx /
# caddy / traefik / Cloudflare without enumerating any CIDRs.
#
# RECOMMENDED for any real deployment: set trusted_proxies to your reverse
# proxy's IP. The panel then verifies the TCP peer IS that proxy before it
# trusts X-Forwarded-For — so an attacker who can reach the listen port
# directly can't forge XFF to spoof their IP and bypass the per-IP rate
# limiter (/login, /sub abuse protection) or poison the IP in audit /
# subscription logs. Leaving it unset is only safe if the listen port is
# unreachable except through your proxy.
#
# http:
#   trusted_proxies: "127.0.0.1,::1"     # your reverse proxy (same host)
#   # trusted_proxies: "10.0.0.0/8"      # or the proxy's subnet / CDN range
#   # trusted_proxies: "none"            # no proxy at all: use raw TCP peer
#
# Env override: PSP_TRUSTED_PROXIES.

# Generate (PowerShell):
#   -join ((48..57)+(65..90)+(97..122) | Get-Random -Count 48 | % {[char]$_})
# or set env PSP_JWT_SECRET instead.
jwt_secret: "CHANGE-ME-TO-RANDOM-48-CHAR-STRING"

# Separate key for encrypting database secrets at rest. Keep it stable; losing
# it prevents decrypting saved 3X-UI/OIDC/SAML/SMTP credentials.
# Env override: PSP_ENCRYPTION_KEY.
encryption_key: "CHANGE-ME-TO-RANDOM-48-CHAR-STRING"

# YAML config directory (templates).
config_dir: "./config"

# Runtime data dir. With the default SQLite setup, the DB file is:
#   ./data/panel.db
data_dir: "./data"

# Optional database connection.
#
# Default: leave the whole mysql block commented out to use embedded SQLite
# at <data_dir>/panel.db. Zero-config, no extra setup needed.
#
# To use a custom SQLite file path:
# mysql:
#   dsn: "sqlite:./data/my-custom.db"
#
# To use MySQL, uncomment and fill in the fields below:
#
# mysql:
#   host: "127.0.0.1"        # MySQL server hostname or IP
#   port: 3306               # TCP port (default 3306)
#   user: "psp"              # MySQL username
#   password: "your_password"
#   database: "passwall"     # database name (must already exist)
#   # params: ""             # extra DSN params; blank uses the safe default
#                            # (parseTime=true&charset=utf8mb4&loc=UTC)
#
# Advanced: set dsn to a raw go-sql-driver string when discrete fields
# don't fit (unix socket, TLS, multi-host, etc.). When set, dsn wins
# over the discrete fields above.
#   dsn: "user:pw@unix(/tmp/mysql.sock)/db?parseTime=true"
#
# Env override: PSP_MYSQL_DSN replaces everything in this block.

# To use PostgreSQL, uncomment and fill in the postgres block below (same
# discrete-field style as mysql). Setting postgres.host or postgres.dsn
# selects the PG driver.
#
# postgres:
#   host: "127.0.0.1"        # PostgreSQL server hostname or IP
#   port: 5432               # TCP port (default 5432)
#   user: "psp"              # PG role
#   password: "your_password"
#   database: "passwall"     # database name (must already exist)
#   sslmode: "disable"       # disable | require | verify-full | ... (default disable)
#   # params: ""             # extra &k=v query params (e.g. connect_timeout=10)
#
# Advanced: set dsn to a raw connection string (URL "postgres://…" or libpq
# keyword form) when discrete fields don't fit. When set, dsn wins.
#   dsn: "postgres://psp:pw@127.0.0.1:5432/passwall?sslmode=disable"
#
# Env override: PSP_POSTGRES_DSN replaces everything in the postgres block.
